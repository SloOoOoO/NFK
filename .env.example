# NFK Steuerberatungsportal – Environment Variables Example
# Copy this file to .env and fill in the values for your environment.
# Never commit your actual .env file to source control.

# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────
SA_PASSWORD=YourStrong@Password123
DB_NAME=NFK

# ──────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-key-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# RSA keys for token signing are loaded from PEM files at runtime.
# These files must NEVER be committed to source control (*.pem is in .gitignore).
# Generate them locally with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=private.pem
JWT_PUBLIC_KEY_PATH=public.pem

# ──────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api/v1
# Google reCAPTCHA site key (use Google's test key for local dev):
VITE_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI

# ──────────────────────────────────────────
# Email (SMTP / Mailpit for local dev)
# ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@nfk.local

# ──────────────────────────────────────────
# Redis (session / rate-limiting cache)
# ──────────────────────────────────────────
REDIS_CONNECTION_STRING=localhost:6379

# ──────────────────────────────────────────
# Google OAuth (optional)
# ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────
# DATEV OAuth (optional)
# ──────────────────────────────────────────
DATEV_CLIENT_ID=
DATEV_CLIENT_SECRET=
